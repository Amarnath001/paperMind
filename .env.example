# Database
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/papermind

# Redis
REDIS_URL=redis://localhost:6379/0

# Storage (local by default; set to "s3" in production if desired)
STORAGE_PROVIDER=local
S3_BUCKET_NAME=
S3_REGION=
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_ENDPOINT_URL=

# Gemini (LLM provider for generation-only tasks)
# Obtain an API key from Google AI Studio: https://ai.google.dev/
GEMINI_API_KEY=
