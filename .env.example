# CORS (comma-separated; must include your frontend origin, e.g. Vercel URL)
# CORS_ORIGINS=https://paper-mind.vercel.app,https://paper-mind-pla.vercel.app,http://localhost:3000

# Database
PAPERMIND_DATABASE_URL=postgresql://postgres:postgres@localhost:5432/papermind
# For Docker: set PAPERMIND_DATABASE_URL so shell env doesn't override (e.g. Neon URL)
# PAPERMIND_DATABASE_URL=

# Redis
PAPERMIND_REDIS_URL=redis://localhost:6379/0
# For Docker: set PAPERMIND_REDIS_URL so shell env doesn't override (e.g. Upstash URL)
# PAPERMIND_REDIS_URL=

# Storage (local by default; set STORAGE_PROVIDER=s3 for R2/S3)
STORAGE_PROVIDER=local
S3_BUCKET_NAME=
# For Cloudflare R2 use S3_REGION=auto
S3_REGION=auto
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
# R2: https://<ACCOUNT_ID>.r2.cloudflarestorage.com
S3_ENDPOINT_URL=

# Gemini (LLM + embeddings in production)
# Obtain an API key from Google AI Studio: https://ai.google.dev/
GEMINI_API_KEY=
# GEMINI_MODEL=gemini-1.5-flash

# Lightweight deployment (Railway/Vercel/Render): no worker, Gemini embeddings
# EMBEDDING_PROVIDER=gemini
# EMBEDDING_MODEL=models/text-embedding-004
# EMBEDDING_DIMENSION=384
# ASYNC_PROCESSING=false
# ENABLE_LOCAL_RERANKING=false
# ENABLE_CLUSTERING=false
# LIGHTWEIGHT_DEPLOYMENT=true
